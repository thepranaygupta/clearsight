{
  "manifest_version": 3,
  "name": "ClearSight - Accessibility Scanner",
  "description": "Scan the current page for WCAG 2.1 accessibility issues with one click",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Scan this page with ClearSight",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "storage"]
}

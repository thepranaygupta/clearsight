generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ScanStatus {
  queued
  running
  completed
  failed
  completed_partial
  cancelled
}

enum IssueType {
  confirmed
  potential
}

enum Severity {
  critical
  serious
  moderate
  minor
}

enum WcagLevel {
  A
  AA
  AAA
}

enum CrawlStatus {
  queued
  discovering
  scanning
  completed
  failed
  cancelled
}

enum IssueStatus {
  open
  fixed
  dismissed
  cant_fix
}

model Scan {
  id             String     @id @default(uuid())
  url            String
  status         ScanStatus @default(queued)
  progress       Int        @default(0)
  currentStage   String?    @map("current_stage")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  completedAt    DateTime?  @map("completed_at")
  pageTitle      String?    @map("page_title")
  pageScreenshot String?    @map("page_screenshot")
  pageHtml       String?    @map("page_html")
  errorMessage   String?    @map("error_message")
  retryCount     Int        @default(0) @map("retry_count")
  metadata       Json?
  pageId         String?    @map("page_id")
  crawlId        String?    @map("crawl_id")

  issues  Issue[]
  summary ScanSummary?
  page    Page?  @relation(fields: [pageId], references: [id], onDelete: SetNull)
  crawl   Crawl? @relation(fields: [crawlId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([crawlId])
  @@map("scans")
}

model Issue {
  id              String    @id @default(uuid())
  scanId          String    @map("scan_id")
  type            IssueType
  severity        Severity
  confidenceScore Float?    @map("confidence_score")
  wcagCriterion   String    @map("wcag_criterion")
  wcagLevel       WcagLevel @map("wcag_level")
  elementSelector String    @map("element_selector")
  elementHtml     String    @map("element_html")
  description     String
  fixSuggestion   String    @map("fix_suggestion")
  axeRuleId       String?   @map("axe_rule_id")
  ruleId          String?   @map("rule_id")
  ruleHelp        String?   @map("rule_help")
  elementBoundingBox Json?       @map("element_bounding_box")
  createdAt       DateTime       @default(now()) @map("created_at")
  issueHash       String?        @map("issue_hash")
  issueStatus     IssueStatus    @default(open) @map("issue_status")
  pageUrl         String?        @map("page_url")
  firstSeenScanId String?        @map("first_seen_scan_id")
  lastSeenScanId  String?        @map("last_seen_scan_id")
  fixedAtCrawlId  String?        @map("fixed_at_crawl_id")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([issueHash])
  @@index([issueStatus])
  @@index([scanId, issueHash])
  @@map("issues")
}

model ScanSummary {
  id               String   @id @default(uuid())
  scanId           String   @unique @map("scan_id")
  overallScore     Int      @map("overall_score")
  summary          String
  topPriorities    Json     @map("top_priorities")
  positiveFindings Json     @map("positive_findings")
  createdAt        DateTime @default(now()) @map("created_at")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@map("scan_summaries")
}

model Site {
  id        String   @id @default(uuid())
  hostname  String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  crawls Crawl[]
  pages  Page[]

  @@map("sites")
}

model Crawl {
  id            String      @id @default(uuid())
  siteId        String      @map("site_id")
  status        CrawlStatus @default(queued)
  totalPages    Int         @default(0) @map("total_pages")
  scannedPages  Int         @default(0) @map("scanned_pages")
  enrichedPages Int         @default(0) @map("enriched_pages")
  overallScore  Float?      @map("overall_score")
  maxPages      Int?        @map("max_pages")
  newIssues     Int         @default(0) @map("new_issues")
  fixedIssues   Int         @default(0) @map("fixed_issues")
  createdAt     DateTime    @default(now()) @map("created_at")
  completedAt   DateTime?   @map("completed_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  site  Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  scans Scan[]
  pages Page[] @relation("firstSeenCrawl")

  @@index([siteId])
  @@index([status])
  @@map("crawls")
}

model Page {
  id               String   @id @default(uuid())
  siteId           String   @map("site_id")
  url              String
  path             String
  firstSeenCrawlId String   @map("first_seen_crawl_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  site           Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  firstSeenCrawl Crawl  @relation("firstSeenCrawl", fields: [firstSeenCrawlId], references: [id])
  scans          Scan[]

  @@unique([siteId, url])
  @@index([siteId])
  @@map("pages")
}

# Database
DATABASE_URL="postgresql://clearsight:clearsight@localhost:5432/clearsight"

# Azure OpenAI
AZURE_OPENAI_ENDPOINT="https://your-endpoint.openai.azure.com/openai/deployments/your-model/chat/completions?api-version=2025-01-01-preview"
AZURE_OPENAI_API_KEY="your-api-key-here"
AZURE_OPENAI_API_VERSION="2025-01-01-preview"

# Redis (required for BullMQ job queues)
REDIS_URL="redis://localhost:6379"

# Crawler (optional)
# MAX_CRAWL_PAGES=
# CRAWL_DELAY_MS="200"

# Worker (optional)
# WORKER_CONCURRENCY="3"
# AI_CONCURRENCY="2"
# BULL_BOARD_PORT="3001"
